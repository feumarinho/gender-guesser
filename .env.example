# Copie para .env e ajuste. Obrigatório para /guess (header x-gender-guesser-api-key).
GENDER_GUESSER_API_KEY=defina-uma-chave-segura

# Modo: offline | hybrid | online
GENDER_MODE=hybrid

# Caminhos dentro do container (use volume em /app/data)
LOCAL_DB_PATH=/app/data/gender_data.db
CACHE_DB_PATH=/app/data/cache.db
CACHE_TTL_DAYS=30

IBGE_FALLBACK_ENABLED=true
LOCAL_CONFIDENCE_THRESHOLD=0.7

RATE_LIMIT_PER_MIN=60
LOG_LEVEL=INFO
PORT=5000
